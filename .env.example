# UYSA ERP v3.0 — Ortam Değişkenleri
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun
# Railway'de bu değerler "Variables" panelinden girilir

# ── Veritabanı (Railway MySQL) ────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=uysa_db
DB_USER=root
DB_PASS=

# ── API Güvenlik Tokeni ───────────────────────────────────────
# openssl rand -hex 32 ile güçlü token oluşturun
# index.html içindeki CFG.token ile EŞLEŞMELİDİR
API_TOKEN=change_me_to_a_strong_random_token

# ── Yedek Yönetimi ────────────────────────────────────────────
BACKUP_MAX=30

# ── Dosya Yükleme ─────────────────────────────────────────────
UPLOAD_DIR=/var/www/html/uploads
UPLOAD_MAX_MB=25
